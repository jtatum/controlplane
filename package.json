{
  "name": "controlplane",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently -n api,web,worker -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:api": "pnpm --filter @controlplane/api dev",
    "dev:web": "pnpm --filter @controlplane/web dev",
    "dev:worker": "pnpm --filter @controlplane/worker dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "pnpm --filter @controlplane/api exec tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  }
}
