# Database
DATABASE_URL=postgresql://controlplane:controlplane@localhost:5432/controlplane

# OIDC authentication
OIDC_ISSUER=https://sso.disney.com
OIDC_CLIENT_ID=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=controlplane

# AWS
AWS_REGION=us-west-2
SUBNET_ID=
SECURITY_GROUP_ID=
INSTANCE_PROFILE_ARN=

# Worker tuning
MAX_CONCURRENT_WORKFLOW_TASKS=100
MAX_CONCURRENT_ACTIVITY_TASKS=200

# API server
PORT=3000

# Dev mode — set to "true" to bypass OIDC auth and use a local dev user
DEV_MODE=true
VITE_DEV_MODE=true
